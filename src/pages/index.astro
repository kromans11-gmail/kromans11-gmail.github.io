---
import Base from '../layouts/Base.astro';
import AppRow from '../components/AppRow.astro';
import apps from '../data/apps.json';
import { CAPABILITY_LABELS } from '../data/capabilities';
import { SUPABASE } from '../data/supabase';

const usedCaps = new Set(apps.flatMap((app) => app.capabilities));
const filterCaps = Object.keys(CAPABILITY_LABELS).filter((c) => usedCaps.has(c));

const catId = (name: string) =>
  name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

const sorted = [...apps].sort((a, b) => b.popularity - a.popularity);

// Apps flagged "spotlight" rotate between Featured and Highly Useful: each
// day a different window of 3 is Featured and the rest fall to Highly Useful.
// This build-time split is a default; a client script re-applies the same
// formula with the visitor's current date so the rotation advances daily
// without rebuilding the site.
const pool = sorted.filter((app) => app.spotlight);
const FEATURED_COUNT = Math.min(3, pool.length);
const dayOfYear = Math.floor(
  (Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000
);
const offset = pool.length ? dayOfYear % pool.length : 0;
const featured = Array.from(
  { length: FEATURED_COUNT },
  (_, i) => pool[(offset + i) % pool.length]
);
const featuredSlugs = new Set(featured.map((app) => app.slug));
const highlyUseful = pool.filter((app) => !featuredSlugs.has(app.slug));

// Apps added in the last week live solely on the "New apps" shelf before
// graduating to their category. The build renders a 14-day candidate window
// (deploys happen at least weekly); a client script applies the exact 7-day
// cutoff with the visitor's date and moves graduates to their category, so
// the shelf stays correct without a rebuild.
const NEW_APP_DAYS = 7;
const isNewCandidate = (app: { addedAt?: string }) =>
  app.addedAt && Date.now() - new Date(app.addedAt).getTime() < 14 * 86400000;
const newApps = sorted
  .filter(isNewCandidate)
  .sort((a, b) => (b.addedAt! < a.addedAt! ? -1 : 1));

// Group into categories, ordered by the total popularity of their apps so the
// strongest categories appear first.
const byCategory = new Map<string, typeof sorted>();
for (const app of sorted.filter((app) => !isNewCandidate(app))) {
  const list = byCategory.get(app.category) ?? [];
  list.push(app);
  byCategory.set(app.category, list);
}
const categories = [...byCategory.entries()].sort(
  (a, b) =>
    b[1].reduce((s, x) => s + x.popularity, 0) -
    a[1].reduce((s, x) => s + x.popularity, 0)
);
---

<Base
  title="Web App Finder — discover the best Progressive Web Apps"
  description="A curated, ranked directory of the best web apps. Installable PWAs are highlighted; great non-PWA web apps that run fully in the browser are listed too."
>
  <section class="hero" id="top">
    <h1>Find the best Progressive Web Apps</h1>
    <p>
      Web apps ranked by popularity and organized by category. Installable
      PWAs take the spotlight, and we also list great non-PWA web apps — as
      long as they're fully useful right in the browser, no install needed.
      Every listing is one tap away from running; nothing requires an app
      store.
    </p>
    <div class="search-wrap">
      <input
        id="search"
        type="search"
        placeholder="Search apps, categories, or features…"
        autocomplete="off"
        aria-label="Search apps"
      />
      <select id="jump" aria-label="Jump to category">
        <option value="" selected>Categories…</option>
        <option value="featured">✨ Featured</option>
        <option value="highly-useful">⭐ Highly Useful</option>
        {newApps.length > 0 && <option value="new-apps">🆕 New apps</option>}
        {categories.map(([name]) => <option value={catId(name)}>{name}</option>)}
      </select>
    </div>
    <div class="filters" role="group" aria-label="Filter apps">
      <button class="filter-chip status-verified" data-status="true" aria-pressed="false">
        ✔ Verified
      </button>
      <button class="filter-chip status-risk" data-status="false" aria-pressed="false">
        ⚠ At your own risk
      </button>
      <button class="filter-chip status-unverifiable" data-status="unverifiable" aria-pressed="false">
        🔒 Unverifiable
      </button>
      <button class="filter-chip pwa-chip" data-pwa="true" aria-pressed="false">
        📲 Installable PWA
      </button>
      <button class="filter-chip pwa-chip" data-pwa="false" aria-pressed="false">
        🌐 Non-PWA
      </button>
      {
        filterCaps.map((c) => (
          <button class="filter-chip" data-cap={c} aria-pressed="false">
            {CAPABILITY_LABELS[c]}
          </button>
        ))
      }
    </div>
  </section>

  <!-- Filled client-side from this device's open history; stays hidden until
       the visitor has opened an app at least twice. -->
  <section class="category" id="personal" data-category-section hidden>
    <h2>📌 Personal PWA's <span class="count">apps you open often — saved only on this device</span></h2>
    <div class="list" id="personal-list"></div>
  </section>

  <section class="category" id="featured" data-category-section>
    <h2>✨ Featured <span class="count">rotates daily</span></h2>
    <div class="list" id="featured-list">
      {featured.map((app) => <AppRow app={app} />)}
    </div>
  </section>

  <section class="category" id="highly-useful" data-category-section>
    <h2>⭐ Highly Useful <span class="count">{highlyUseful.length} apps</span></h2>
    <div class="list" id="useful-list">
      {highlyUseful.map((app) => <AppRow app={app} />)}
    </div>
  </section>

  <section class="category" id="new-apps" data-category-section hidden={newApps.length === 0}>
    <h2>
      🆕 New apps — tell us what you think
      <span class="count">listed this week · vote or report on each app's Details page</span>
    </h2>
    <div class="list" id="new-apps-list">
      {newApps.map((app) => <AppRow app={app} />)}
    </div>
  </section>

  {
    categories.map(([name, list]) => (
      <section class="category" id={catId(name)} data-category-section>
        <h2>
          {name} <span class="count">{list.length} apps</span>
          <a class="to-top" href="#top">↑ Back to top</a>
        </h2>
        <div class="list">
          {list.map((app) => (
            <AppRow app={app} />
          ))}
        </div>
      </section>
    ))
  }

  <p class="note" id="no-results" hidden>No apps match your search.</p>
  <p class="note">
    ★ Popularity is a 0–100 score. In v1 it is editorially seeded from adoption,
    reputation, and case-study data; community voting and automated traffic
    signals are on the roadmap.
  </p>

  <script define:vars={{ poolSlugs: pool.map((app) => app.slug) }}>
    // Re-apply the daily Featured/Highly Useful rotation with the visitor's
    // current date, so the split stays fresh even if the site isn't rebuilt.
    const featuredList = document.getElementById('featured-list');
    const usefulList = document.getElementById('useful-list');
    if (featuredList && usefulList && poolSlugs.length) {
      const rows = new Map(
        [...featuredList.children, ...usefulList.children].map((row) => [
          row.dataset.slug,
          row,
        ])
      );
      const now = new Date();
      const dayOfYear = Math.floor(
        (now - new Date(now.getFullYear(), 0, 0)) / 86400000
      );
      const offset = dayOfYear % poolSlugs.length;
      const count = Math.min(3, poolSlugs.length);
      const featured = new Set(
        Array.from({ length: count }, (_, i) => poolSlugs[(offset + i) % poolSlugs.length])
      );
      for (const slug of poolSlugs) {
        const row = rows.get(slug);
        if (row) (featured.has(slug) ? featuredList : usefulList).append(row);
      }
    }
  </script>

  <script define:vars={{ sb: SUPABASE }}>
    // Hide rows for apps suspended pending curator review (any unprocessed
    // community warning suspends; checked live so no rebuild is needed).
    if (sb.url && sb.key) {
      fetch(`${sb.url}/rest/v1/suspended_apps?select=app_slug`, {
        headers: { apikey: sb.key, authorization: `Bearer ${sb.key}` },
      })
        .then((r) => r.json())
        .then((rows) => {
          for (const { app_slug } of rows) {
            document
              .querySelectorAll(`[data-app][data-slug="${CSS.escape(app_slug)}"]`)
              .forEach((el) => el.remove());
          }
        })
        .catch(() => {});
    }
  </script>

  <script>
    // New-apps shelf: apply the exact 7-day window with the visitor's date.
    // Rows older than a week graduate to their category section; the shelf
    // hides itself when empty (build renders a 14-day candidate window).
    {
      const shelf = document.getElementById('new-apps');
      const shelfList = document.getElementById('new-apps-list');
      if (shelf && shelfList) {
        const cutoff = Date.now() - 7 * 86400000;
        for (const row of [...shelfList.children] as HTMLElement[]) {
          if (new Date(row.dataset.added ?? 0).getTime() >= cutoff) continue;
          const home = document.querySelector(`#${row.dataset.cat} .list`);
          if (home) home.append(row);
        }
        shelf.hidden = shelfList.children.length === 0;
      }
    }
  </script>

  <script>
    // Personal PWA's: any app this visitor has opened twice gets pinned in a
    // section at the top. Open counts live only in this browser's storage.
    const OPENS_KEY = 'pwafinder-opens';
    const readOpens = (): Record<string, number> => {
      try {
        return JSON.parse(localStorage.getItem(OPENS_KEY) ?? '{}');
      } catch {
        return {};
      }
    };
    const writeOpens = (c: Record<string, number>) =>
      localStorage.setItem(OPENS_KEY, JSON.stringify(c));

    const personalSection = document.getElementById('personal')!;
    const personalList = document.getElementById('personal-list')!;
    const jumpSelect = document.getElementById('jump') as HTMLSelectElement;
    const personalOption = document.createElement('option');
    personalOption.value = 'personal';
    personalOption.textContent = "📌 Personal PWA's";

    function buildPersonal() {
      personalList.textContent = '';
      const counts = readOpens();
      for (const slug of Object.keys(counts).filter((s) => counts[s] >= 2)) {
        const original = document.querySelector<HTMLElement>(
          `[data-app][data-slug="${slug}"]`
        );
        if (!original) continue; // app no longer in the catalog
        const clone = original.cloneNode(true) as HTMLElement;
        const remove = document.createElement('button');
        remove.className = 'remove-personal';
        remove.textContent = '✕';
        remove.title = "Remove from Personal PWA's";
        remove.setAttribute('aria-label', `Remove ${slug} from Personal PWA's`);
        remove.addEventListener('click', () => {
          const c = readOpens();
          delete c[slug];
          writeOpens(c);
          clone.remove();
          syncPersonalVisibility();
          collectCards();
        });
        clone.append(remove);
        personalList.append(clone);
      }
      syncPersonalVisibility();
    }

    function syncPersonalVisibility() {
      const has = personalList.children.length > 0;
      personalSection.hidden = !has;
      const present = jumpSelect.querySelector('option[value="personal"]');
      if (has && !present) jumpSelect.insertBefore(personalOption, jumpSelect.options[1]);
      if (!has && present) present.remove();
    }

    buildPersonal();

    // Count opens from the list rows (each app link opens in a new tab, so
    // this page stays alive to record the click).
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest<HTMLElement>('[data-app] .row-main');
      if (!link) return;
      const slug = link.closest<HTMLElement>('[data-app]')!.dataset.slug!;
      const c = readOpens();
      c[slug] = (c[slug] ?? 0) + 1;
      writeOpens(c);
      if (c[slug] === 2) {
        buildPersonal();
        collectCards();
        applyFilters();
      }
    });

    const input = document.getElementById('search') as HTMLInputElement;
    let cards = [...document.querySelectorAll<HTMLElement>('[data-app]')];
    const collectCards = () => {
      cards = [...document.querySelectorAll<HTMLElement>('[data-app]')];
    };
    const sections = [...document.querySelectorAll<HTMLElement>('[data-category-section]')];
    const chips = [...document.querySelectorAll<HTMLButtonElement>('.filter-chip[data-cap]')];
    const statusChips = [...document.querySelectorAll<HTMLButtonElement>('.filter-chip[data-status]')];
    const pwaChips = [...document.querySelectorAll<HTMLButtonElement>('.filter-chip[data-pwa]')];
    const noResults = document.getElementById('no-results')!;
    const activeCaps = new Set<string>();
    const activeStatus = new Set<string>();
    const activePwa = new Set<string>();

    function applyFilters() {
      const q = input?.value.trim().toLowerCase() ?? '';
      for (const card of cards) {
        const caps = (card.dataset.caps ?? '').split(' ');
        const matchesText = !q || card.dataset.text!.includes(q);
        const matchesCaps = [...activeCaps].every((c) => caps.includes(c));
        const matchesStatus =
          activeStatus.size === 0 || activeStatus.has(card.dataset.verified!);
        const matchesPwa = activePwa.size === 0 || activePwa.has(card.dataset.pwa!);
        card.classList.toggle(
          'hidden',
          !(matchesText && matchesCaps && matchesStatus && matchesPwa)
        );
      }
      let anyVisible = false;
      for (const section of sections) {
        const visible = section.querySelector('[data-app]:not(.hidden)') !== null;
        section.classList.toggle('hidden', !visible);
        anyVisible ||= visible;
      }
      noResults.hidden = anyVisible;
    }

    function toggleCap(cap: string) {
      if (activeCaps.has(cap)) activeCaps.delete(cap);
      else activeCaps.add(cap);
      for (const chip of chips) {
        const on = activeCaps.has(chip.dataset.cap!);
        chip.classList.toggle('active', on);
        chip.setAttribute('aria-pressed', String(on));
      }
      document
        .querySelectorAll<HTMLElement>('[data-app] .badge[data-cap]')
        .forEach((b) => b.classList.toggle('active', activeCaps.has(b.dataset.cap!)));
      applyFilters();
    }

    input?.addEventListener('input', applyFilters);
    for (const chip of statusChips) {
      chip.addEventListener('click', () => {
        const v = chip.dataset.status!;
        if (activeStatus.has(v)) activeStatus.delete(v);
        else activeStatus.add(v);
        const on = activeStatus.has(v);
        chip.classList.toggle('active', on);
        chip.setAttribute('aria-pressed', String(on));
        applyFilters();
      });
    }
    for (const chip of pwaChips) {
      chip.addEventListener('click', () => {
        const v = chip.dataset.pwa!;
        if (activePwa.has(v)) activePwa.delete(v);
        else activePwa.add(v);
        const on = activePwa.has(v);
        chip.classList.toggle('active', on);
        chip.setAttribute('aria-pressed', String(on));
        applyFilters();
      });
    }
    const jump = document.getElementById('jump') as HTMLSelectElement;
    jump?.addEventListener('change', () => {
      const target = jump.value && document.getElementById(jump.value);
      if (target) target.scrollIntoView({ behavior: 'smooth' });
      jump.value = '';
    });
    for (const chip of chips) {
      chip.addEventListener('click', () => toggleCap(chip.dataset.cap!));
    }
    // The badges on each row toggle the same filters.
    document.addEventListener('click', (e) => {
      const badge = (e.target as HTMLElement).closest<HTMLElement>(
        '[data-app] .badge[data-cap]'
      );
      if (badge) toggleCap(badge.dataset.cap!);
    });
  </script>
</Base>
