---
import Base from '../../layouts/Base.astro';
import apps from '../../data/apps.json';
import { capabilityLabel } from '../../data/capabilities';
import { SUPABASE } from '../../data/supabase';
import screenshotData from '../../data/screenshots.json';

export function getStaticPaths() {
  return apps.map((app) => ({ params: { slug: app.slug }, props: { app } }));
}

const { app } = Astro.props;

const screenshots: { src: string; label?: string }[] =
  (screenshotData as Record<string, { src: string; label?: string }[]>)[app.slug] ?? [];
---

<Base title={`${app.name} — Web App Finder`} description={app.tagline}>
  <article class="detail">
    <a class="back-link" href="/">← Back to home</a>
    <div class="card-head">
      <span class="app-icon" aria-hidden="true">{app.icon}</span>
      <div>
        <h1>{app.name}</h1>
        <p class="tagline">{app.category}</p>
      </div>
      <span class="pop" title="Popularity score (0–100)">★ {app.popularity}</span>
    </div>

    <p>{app.description}</p>

    <div class="badges">
      {
        app.pwa === false && (
          <a
            class="nonpwa-badge"
            href="/verification/#non-pwa"
            title="Runs in the browser tab — not installable as an app"
          >
            🌐 Non-PWA web app — what this means
          </a>
        )
      }
      {
        app.verified === true ? (
          <a
            class="verified-badge"
            href="/verification/"
            title="See how verification works"
          >
            ✔ Verified publisher — how we verify
          </a>
        ) : app.verified === 'unverifiable' ? (
          <a
            class="unverifiable-badge"
            href="/verification/#unverifiable"
            title="Hidden behind a sign-in page — we can't check it either way"
          >
            🔒 Unverifiable — what this means
          </a>
        ) : (
          <a
            class="risk-badge"
            href="/verification/#at-your-own-risk"
            title="Community listing — not verified"
          >
            ⚠ At your own risk — what this means
          </a>
        )
      }
      {app.capabilities.map((c) => <span class="badge">{capabilityLabel(c)}</span>)}
    </div>

    <div class="actions">
      <a class="btn primary" href={app.url} target="_blank" rel="noopener">
        Open {app.name} ↗
      </a>
      <button class="btn vote-btn" id="vote-btn" hidden>
        👍 Useful · <span id="vote-count">…</span>
      </button>
      <button class="btn warn-btn" id="warn-btn" hidden>⚠ Report a problem</button>
      <a class="btn" href="/">← Back to home</a>
    </div>

    <form class="comment-box warn-form" id="warn-form" hidden>
      <p><strong>Report a problem with {app.name}</strong> — goes privately to the curator, who reviews every report.</p>
      <fieldset id="warn-reasons">
        <label><input type="checkbox" value="broken" /> Doesn't load or is broken</label>
        <label><input type="checkbox" value="misleading" /> Misleading — not what it claims to be</label>
        <label><input type="checkbox" value="permissions" /> Asks for permissions it shouldn't need</label>
        <label><input type="checkbox" value="scam" /> Suspected scam or phishing</label>
        <label><input type="checkbox" value="adult" /> Adult content</label>
        <label><input type="checkbox" value="ads" /> Excessive ads or an immediate paywall</label>
      </fieldset>
      <textarea
        id="warn-comment"
        minlength="10"
        maxlength="500"
        rows="3"
        required
        placeholder="Required: describe what you saw (at least 10 characters)"
      ></textarea>
      <div class="actions">
        <button class="btn primary" type="submit">Send report</button>
        <button class="btn" type="button" id="warn-cancel">Cancel</button>
      </div>
      <p class="note" id="warn-status" hidden></p>
    </form>

    <div class="comment-box" id="comment-box" hidden>
      <textarea
        id="vote-comment"
        maxlength="500"
        rows="2"
        placeholder="Optional: say why it's useful — posted publicly with your vote"
      ></textarea>
    </div>

    <section class="comments" id="comments" hidden aria-label="Community comments">
      <h2>What the community says</h2>
      <ul id="comment-list"></ul>
    </section>

    {
      screenshots.length > 0 && (
        <div class="screenshots" aria-label="Screenshots from the app's manifest">
          {screenshots.map((s) => (
            <img
              src={s.src}
              alt={s.label || `${app.name} screenshot`}
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          ))}
        </div>
      )
    }

    {
      app.pwa === false ? (
        <div class="install-help">
          <h2>Runs in your browser — pin it like an app</h2>
          <p>
            {app.name} is a regular web app, not a PWA, so it won't offer an
            install button. Your browser can still pin it with its own icon
            and window:
          </p>
          <ol data-platform="desktop">
            <li>Open <a href={app.url} target="_blank" rel="noopener">{new URL(app.url).hostname}</a> in Chrome or Edge.</li>
            <li>Chrome: ⋮ menu → “Cast, save, and share” → “Install page as app…”. Edge: ⋯ menu → “Apps” → “Install this site as an app”.</li>
          </ol>
          <ol data-platform="android" hidden>
            <li>Open the app in Chrome on Android.</li>
            <li>Tap the ⋮ menu → “Add to Home screen” → “Add”.</li>
          </ol>
          <ol data-platform="ios" hidden>
            <li>Open the app in Safari on iOS.</li>
            <li>Tap the Share button → “Add to Home Screen”.</li>
          </ol>
          <p class="note">
            Pinning gives you a shortcut in an app-style window; offline use
            and notifications stay up to the publisher.{' '}
            <a href="/verification/#non-pwa">What “Non-PWA” means →</a>
          </p>
        </div>
      ) : (
        <div class="install-help">
          <h2>How to install it as an app</h2>
          <ol data-platform="desktop">
            <li>Open <a href={app.url} target="_blank" rel="noopener">{new URL(app.url).hostname}</a> in Chrome or Edge.</li>
            <li>Click the install icon in the address bar (or menu → “Install app”).</li>
          </ol>
          <ol data-platform="android" hidden>
            <li>Open the app in Chrome on Android.</li>
            <li>Tap the ⋮ menu → “Add to Home screen” or “Install app”.</li>
          </ol>
          <ol data-platform="ios" hidden>
            <li>Open the app in Safari on iOS.</li>
            <li>Tap the Share button → “Add to Home Screen”.</li>
          </ol>
        </div>
      )
    }
  </article>

  <script define:vars={{ slug: app.slug, sb: SUPABASE }}>
    // Count opens toward the home page's "Personal PWA's" section (two opens
    // pin the app there; the count lives only in this browser's storage).
    document.querySelector('.actions .btn.primary')?.addEventListener('click', () => {
      try {
        const c = JSON.parse(localStorage.getItem('pwafinder-opens') ?? '{}');
        c[slug] = (c[slug] ?? 0) + 1;
        localStorage.setItem('pwafinder-opens', JSON.stringify(c));
      } catch {}
    });

    // Community voting: one vote per device per app, stored in Supabase.
    // A vote may carry an optional public comment (same row, shown via the
    // app_comments view, which exposes no device ids).
    const btn = document.getElementById('vote-btn');
    const countEl = document.getElementById('vote-count');
    const commentBox = document.getElementById('comment-box');
    const commentInput = document.getElementById('vote-comment');
    const commentsSection = document.getElementById('comments');
    const commentList = document.getElementById('comment-list');
    if (sb.url && sb.key && btn) {
      const headers = { apikey: sb.key, authorization: `Bearer ${sb.key}` };

      // Immediate suspension: any unprocessed warning pulls the app pending
      // curator review (checked live, so no rebuild is needed to suspend or
      // restore). The Open button is disabled and a notice shown.
      fetch(
        `${sb.url}/rest/v1/suspended_apps?app_slug=eq.${encodeURIComponent(slug)}`,
        { headers }
      )
        .then((r) => r.json())
        .then((rows) => {
          if (!rows.length) return;
          const open = document.querySelector('.actions .btn.primary');
          if (open) {
            open.removeAttribute('href');
            open.setAttribute('aria-disabled', 'true');
            open.classList.add('suspended');
            open.textContent = '⏸ Temporarily suspended';
          }
          const notice = document.createElement('p');
          notice.className = 'note suspend-note';
          notice.textContent =
            'This listing is suspended while the curator reviews a community report. It will be restored if the report is not confirmed.';
          document.querySelector('.actions')?.after(notice);
        })
        .catch(() => {});
      const deviceId =
        localStorage.getItem('pwafinder-device') ??
        (() => {
          const id = crypto.randomUUID();
          localStorage.setItem('pwafinder-device', id);
          return id;
        })();
      const votedKey = 'pwafinder-voted';
      const voted = () => new Set(JSON.parse(localStorage.getItem(votedKey) ?? '[]'));
      const setVoted = (s) => localStorage.setItem(votedKey, JSON.stringify([...s]));

      let count = 0;
      const render = () => {
        countEl.textContent = String(count);
        const hasVoted = voted().has(slug);
        btn.classList.toggle('voted', hasVoted);
        // The comment rides along with the vote, so the box only shows
        // before you have voted.
        commentBox.hidden = hasVoted || btn.hidden;
      };

      const loadComments = async () => {
        try {
          const res = await fetch(
            `${sb.url}/rest/v1/app_comments?app_slug=eq.${encodeURIComponent(slug)}&order=created_at.desc&limit=50`,
            { headers }
          );
          if (!res.ok) return;
          const rows = await res.json();
          commentList.textContent = '';
          for (const row of rows) {
            const li = document.createElement('li');
            const p = document.createElement('p');
            p.textContent = row.comment; // textContent: comments are untrusted
            const time = document.createElement('time');
            time.textContent = new Date(row.created_at).toLocaleDateString();
            li.append(p, time);
            commentList.append(li);
          }
          commentsSection.hidden = rows.length === 0;
        } catch {}
      };

      fetch(`${sb.url}/rest/v1/vote_counts?app_slug=eq.${encodeURIComponent(slug)}`, { headers })
        .then((r) => r.json())
        .then((rows) => {
          count = rows[0]?.votes ?? 0;
          btn.hidden = false;
          render();
        })
        .catch(() => {});
      loadComments();

      btn.addEventListener('click', async () => {
        btn.disabled = true;
        const v = voted();
        try {
          if (v.has(slug)) {
            // Vote rows are unreadable by design, so withdrawal goes through
            // a security-definer function instead of a direct DELETE. The
            // row's comment (if any) is deleted with it.
            await fetch(`${sb.url}/rest/v1/rpc/unvote`, {
              method: 'POST',
              headers: { ...headers, 'content-type': 'application/json' },
              body: JSON.stringify({ p_app_slug: slug, p_device_id: deviceId }),
            });
            v.delete(slug);
            count = Math.max(0, count - 1);
            loadComments();
          } else {
            const comment = commentInput.value.trim().slice(0, 500);
            const body = { app_slug: slug, device_id: deviceId };
            if (comment) body.comment = comment;
            const res = await fetch(`${sb.url}/rest/v1/votes`, {
              method: 'POST',
              headers: { ...headers, 'content-type': 'application/json', prefer: 'return=minimal' },
              body: JSON.stringify(body),
            });
            if (res.ok || res.status === 409) v.add(slug);
            if (res.ok) {
              count += 1;
              if (comment) {
                commentInput.value = '';
                loadComments();
              }
            }
          }
          setVoted(v);
          render();
        } catch {}
        btn.disabled = false;
      });

      // Problem reports: write-only to the private warnings table (no select
      // policy — reports are visible only to the curator). One per device per
      // app; commentary is required.
      const warnBtn = document.getElementById('warn-btn');
      const warnForm = document.getElementById('warn-form');
      const warnComment = document.getElementById('warn-comment');
      const warnStatus = document.getElementById('warn-status');
      const warnedKey = 'pwafinder-warned';
      const warned = () => new Set(JSON.parse(localStorage.getItem(warnedKey) ?? '[]'));
      warnBtn.hidden = false;
      if (warned().has(slug)) warnBtn.textContent = '⚠ Problem reported — thanks';
      warnBtn.addEventListener('click', () => {
        if (warned().has(slug)) return;
        warnForm.hidden = !warnForm.hidden;
      });
      document.getElementById('warn-cancel').addEventListener('click', () => {
        warnForm.hidden = true;
      });
      warnForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const comment = warnComment.value.trim();
        if (comment.length < 10) return;
        const reasons = [...warnForm.querySelectorAll('#warn-reasons input:checked')].map(
          (c) => c.value
        );
        try {
          const res = await fetch(`${sb.url}/rest/v1/warnings`, {
            method: 'POST',
            headers: { ...headers, 'content-type': 'application/json', prefer: 'return=minimal' },
            body: JSON.stringify({ app_slug: slug, device_id: deviceId, reasons, comment }),
          });
          if (res.ok || res.status === 409) {
            const w = warned();
            w.add(slug);
            localStorage.setItem(warnedKey, JSON.stringify([...w]));
            warnForm.hidden = true;
            warnBtn.textContent = '⚠ Problem reported — thanks';
            warnStatus.hidden = true;
          } else {
            warnStatus.textContent = 'Could not send the report — please try again later.';
            warnStatus.hidden = false;
          }
        } catch {
          warnStatus.textContent = 'Could not send the report — please try again later.';
          warnStatus.hidden = false;
        }
      });
    }
  </script>

  <script>
    const ua = navigator.userAgent;
    const platform = /iPhone|iPad|iPod/.test(ua)
      ? 'ios'
      : /Android/.test(ua)
        ? 'android'
        : 'desktop';
    document.querySelectorAll<HTMLElement>('[data-platform]').forEach((el) => {
      el.hidden = el.dataset.platform !== platform;
    });
  </script>
</Base>
